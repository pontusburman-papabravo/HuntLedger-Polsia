# HuntLedger Web — local development env vars.
# Copy to `.env.local` and adjust as needed. Values are exposed to the bundle
# so do NOT put secrets here.

# F2+ — when true, the web app talks to the Fastify backend instead of
# localStorage. Defaults to false in F1.
VITE_USE_BACKEND=false

# F2+ — base URL of the API.
VITE_API_BASE_URL=http://localhost:3001

# F2+ — Firebase web config (only used when VITE_USE_BACKEND=true).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
