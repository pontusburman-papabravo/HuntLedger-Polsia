# HuntLedger API — local development env vars.
# Copy this file to `.env` and adjust as needed.

# HTTP listen port.
PORT=3001

# Bind address. Use 0.0.0.0 inside containers, 127.0.0.1 for local-only.
HOST=127.0.0.1

# Allowed CORS origin for the web app.
CORS_ORIGIN=http://localhost:5173

# F2+ — connection string for Postgres (unused in F1).
# DATABASE_URL=postgres://huntledger:huntledger@localhost:5432/huntledger

# F2+ — Firebase project id used to verify ID tokens (unused in F1).
# FIREBASE_PROJECT_ID=huntledger-dev
